{
  "openapi": "3.0.3",
  "info": {
    "title": "geo-line-ranker API",
    "description": "Deterministic geo-first and line-first recommendation API.",
    "license": {
      "name": "MIT"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/healthz": {
      "get": {
        "tags": [
          "system"
        ],
        "operationId": "healthz_doc",
        "responses": {
          "200": {
            "description": "liveness probe",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/readyz": {
      "get": {
        "tags": [
          "system"
        ],
        "operationId": "readyz_doc",
        "responses": {
          "200": {
            "description": "readiness probe",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadyResponse"
                }
              }
            }
          },
          "503": {
            "description": "readiness probe failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadyResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/recommendations": {
      "post": {
        "tags": [
          "recommendations"
        ],
        "operationId": "recommend_doc",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecommendationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "deterministic recommendations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecommendationResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/track": {
      "post": {
        "tags": [
          "tracking"
        ],
        "operationId": "track_doc",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TrackRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "accepted tracking event",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrackResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AreaContext": {
        "type": "object",
        "properties": {
          "city_code": {
            "type": "string",
            "nullable": true
          },
          "city_name": {
            "type": "string",
            "nullable": true
          },
          "country": {
            "type": "string"
          },
          "prefecture_code": {
            "type": "string",
            "nullable": true
          },
          "prefecture_name": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "AreaContextInput": {
        "type": "object",
        "properties": {
          "city_code": {
            "type": "string",
            "nullable": true
          },
          "city_name": {
            "type": "string",
            "nullable": true
          },
          "country": {
            "type": "string",
            "nullable": true
          },
          "prefecture_code": {
            "type": "string",
            "nullable": true
          },
          "prefecture_name": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ContextInput": {
        "type": "object",
        "properties": {
          "area": {
            "allOf": [
              {
                "$ref": "#/components/schemas/AreaContextInput"
              }
            ],
            "nullable": true
          },
          "line_id": {
            "type": "string",
            "nullable": true
          },
          "line_name": {
            "type": "string",
            "nullable": true
          },
          "station_id": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ContextSource": {
        "type": "string",
        "enum": [
          "request_station",
          "request_line",
          "request_area",
          "user_profile_area",
          "recent_search_context",
          "recent_behavior_context",
          "default_safe_context"
        ]
      },
      "ContextWarning": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "FallbackStageDto": {
        "type": "string",
        "enum": [
          "strict_station",
          "same_line",
          "same_city",
          "same_prefecture",
          "neighbor_area",
          "safe_global_popular"
        ]
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "LineContext": {
        "type": "object",
        "required": [
          "line_name"
        ],
        "properties": {
          "line_id": {
            "type": "string",
            "nullable": true
          },
          "line_name": {
            "type": "string"
          },
          "operator_name": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "PrivacyLevel": {
        "type": "string",
        "enum": [
          "coarse_area"
        ]
      },
      "RankingContext": {
        "type": "object",
        "required": [
          "context_source",
          "confidence",
          "privacy_level",
          "fallback_policy",
          "gate_policy"
        ],
        "properties": {
          "area": {
            "allOf": [
              {
                "$ref": "#/components/schemas/AreaContext"
              }
            ],
            "nullable": true
          },
          "confidence": {
            "type": "number",
            "format": "double"
          },
          "context_source": {
            "$ref": "#/components/schemas/ContextSource"
          },
          "fallback_policy": {
            "type": "string"
          },
          "gate_policy": {
            "type": "string"
          },
          "line": {
            "allOf": [
              {
                "$ref": "#/components/schemas/LineContext"
              }
            ],
            "nullable": true
          },
          "privacy_level": {
            "$ref": "#/components/schemas/PrivacyLevel"
          },
          "station": {
            "allOf": [
              {
                "$ref": "#/components/schemas/StationContext"
              }
            ],
            "nullable": true
          },
          "warnings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContextWarning"
            }
          }
        }
      },
      "ReadyResponse": {
        "type": "object",
        "required": [
          "status",
          "database",
          "cache",
          "opensearch"
        ],
        "properties": {
          "cache": {
            "type": "string"
          },
          "database": {
            "type": "string"
          },
          "opensearch": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "RecommendationContextDto": {
        "type": "object",
        "required": [
          "context_source",
          "confidence",
          "privacy_level"
        ],
        "properties": {
          "confidence": {
            "type": "number",
            "format": "double"
          },
          "context_source": {
            "type": "string"
          },
          "privacy_level": {
            "type": "string"
          },
          "warnings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/context.ContextWarning"
            }
          }
        }
      },
      "RecommendationItemDto": {
        "type": "object",
        "required": [
          "content_kind",
          "content_id",
          "school_id",
          "school_name",
          "primary_station_id",
          "primary_station_name",
          "line_name",
          "score",
          "explanation",
          "score_breakdown"
        ],
        "properties": {
          "content_id": {
            "type": "string"
          },
          "content_kind": {
            "type": "string"
          },
          "event_id": {
            "type": "string",
            "nullable": true
          },
          "event_title": {
            "type": "string",
            "nullable": true
          },
          "explanation": {
            "type": "string"
          },
          "fallback_stage": {
            "type": "string",
            "nullable": true
          },
          "line_name": {
            "type": "string"
          },
          "primary_station_id": {
            "type": "string"
          },
          "primary_station_name": {
            "type": "string"
          },
          "school_id": {
            "type": "string"
          },
          "school_name": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "format": "double"
          },
          "score_breakdown": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ScoreComponentDto"
            }
          }
        }
      },
      "RecommendationRequest": {
        "type": "object",
        "properties": {
          "context": {
            "allOf": [
              {
                "$ref": "#/components/schemas/ContextInput"
              }
            ],
            "nullable": true
          },
          "debug": {
            "type": "boolean"
          },
          "limit": {
            "type": "integer",
            "nullable": true,
            "maximum": 20,
            "minimum": 1
          },
          "placement": {
            "type": "string"
          },
          "request_id": {
            "type": "string",
            "nullable": true
          },
          "target_station_id": {
            "type": "string",
            "nullable": true
          },
          "user_id": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "RecommendationResponse": {
        "type": "object",
        "required": [
          "items",
          "explanation",
          "score_breakdown",
          "fallback_stage",
          "candidate_counts",
          "profile_version",
          "algorithm_version"
        ],
        "properties": {
          "algorithm_version": {
            "type": "string"
          },
          "candidate_counts": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 0
            }
          },
          "context": {
            "allOf": [
              {
                "$ref": "#/components/schemas/RecommendationContextDto"
              }
            ],
            "nullable": true
          },
          "explanation": {
            "type": "string"
          },
          "fallback_stage": {
            "$ref": "#/components/schemas/FallbackStageDto"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RecommendationItemDto"
            }
          },
          "profile_version": {
            "type": "string"
          },
          "request_id": {
            "type": "string",
            "nullable": true
          },
          "score_breakdown": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ScoreComponentDto"
            }
          }
        }
      },
      "ScoreComponentDto": {
        "type": "object",
        "required": [
          "feature",
          "value",
          "reason"
        ],
        "properties": {
          "details": {
            "type": "object",
            "nullable": true
          },
          "feature": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "value": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "StationContext": {
        "type": "object",
        "required": [
          "station_id",
          "station_name"
        ],
        "properties": {
          "station_id": {
            "type": "string"
          },
          "station_name": {
            "type": "string"
          }
        }
      },
      "TrackRequest": {
        "type": "object",
        "required": [
          "user_id",
          "event_kind"
        ],
        "properties": {
          "context": {
            "allOf": [
              {
                "$ref": "#/components/schemas/ContextInput"
              }
            ],
            "nullable": true
          },
          "event_id": {
            "type": "string",
            "nullable": true
          },
          "event_kind": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string",
            "nullable": true
          },
          "occurred_at": {
            "type": "string",
            "nullable": true
          },
          "payload": {
            "type": "object",
            "nullable": true
          },
          "school_id": {
            "type": "string",
            "nullable": true
          },
          "target_station_id": {
            "type": "string",
            "nullable": true
          },
          "user_id": {
            "type": "string"
          }
        }
      },
      "TrackResponse": {
        "type": "object",
        "required": [
          "status",
          "event_id",
          "queued_jobs"
        ],
        "properties": {
          "event_id": {
            "type": "string"
          },
          "queued_jobs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "system",
      "description": "System status endpoints"
    },
    {
      "name": "recommendations",
      "description": "Deterministic recommendation endpoints"
    },
    {
      "name": "tracking",
      "description": "Append-only user event tracking"
    }
  ]
}